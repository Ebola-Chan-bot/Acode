{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acode.app/schemas/ai/mcp-manifest.schema.json",
  "title": "Acode MCP Manifest Draft",
  "type": "object",
  "additionalProperties": false,
  "required": ["pluginId", "version", "servers"],
  "properties": {
    "pluginId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "servers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "transport", "disabledByDefault"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "transport": {
            "type": "string",
            "enum": ["stdio", "websocket", "http"]
          },
          "command": {
            "type": "string"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "endpoint": {
            "type": "string"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "disabledByDefault": {
            "type": "boolean"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["network", "workspace-read", "workspace-write", "terminal"]
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "description"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "requiresApproval": {
                  "type": "boolean",
                  "default": true
                },
                "inputSchema": {
                  "type": ["object", "boolean"]
                }
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "transport": {
                  "const": "stdio"
                }
              }
            },
            "then": {
              "required": ["command"]
            }
          },
          {
            "if": {
              "properties": {
                "transport": {
                  "enum": ["websocket", "http"]
                }
              }
            },
            "then": {
              "required": ["endpoint"]
            }
          }
        ]
      }
    }
  }
}